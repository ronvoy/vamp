flowchart TD
    subgraph USER["User Interface — voice.html"]
        A([User Holds Record Button])
        B[MediaRecorder Captures Audio<br/><i>WebM/OGG format</i>]
        C[Preview & Edit Transcribed Text]
        D[Select Model from Dropdown<br/><i>Optional: 80+ OpenRouter models</i>]
        E([User Clicks Send])
    end

    subgraph TRANSCRIBE["Transcription Pipeline — transcriber.py"]
        F[Convert WebM to WAV<br/><i>pydub AudioSegment</i>]
        G[Base64 Encode WAV Data]
        H[OpenRouter API Call<br/><i>google/gemini-2.5-flash</i>]
        I[Return Plain Text Transcript]
    end

    subgraph AGENT["Agent Selection — agent_registry.py"]
        J{Parse Keywords<br/>in Transcript}
        K[GPT Agent<br/><i>openai/gpt-4o-mini</i>]
        L[Claude Agent<br/><i>anthropic/claude-3-5-haiku</i>]
        M[Default Agent<br/><i>from ENV or openai</i>]
        N[Custom Model<br/><i>User-selected from dropdown</i>]
    end

    subgraph CODEGEN["Code Generation — code_generator.py"]
        O[Build System Prompt<br/><i>Multi-language setup.sh generator</i>]
        P[OpenRouter API Call<br/><i>chat.completions.create</i>]
        Q[Parse LLM Response<br/><i>Extract bash script + folder name</i>]
        R[Return Script + Metadata<br/><i>script, folder_name, reasoning, usage</i>]
    end

    subgraph PERSIST["Conversation Store — conversation_store.py"]
        S[Create Folder<br/><i>conversation/YYYY-MM-DD_HHmm_name/</i>]
        T[Write setup.sh]
        U[Execute setup.sh<br/><i>subprocess, 60s timeout</i>]
        V[Write metadata.json<br/><i>task, agent, files, usage, history</i>]
        W[Git Commit<br/><i>author: vamp</i>]
    end

    subgraph RESPONSE["Response to Client"]
        X[Return JSON<br/><i>path, folder, files, reasoning,<br/>usage, script_output</i>]
        Y[Render in UI<br/><i>Files, diffs, output, history</i>]
    end

    A -->|hold & speak| B
    B -->|POST /api/transcribe<br/>audio blob| F
    F --> G --> H --> I
    I -->|transcript text| C
    C --> D --> E

    E -->|POST /api/generate<br/>task + model| J

    J -->|"gpt, openai, chatgpt"| K
    J -->|"claude, anthropic"| L
    J -->|no keyword match| M
    D -.->|user selected model| N

    K --> O
    L --> O
    M --> O
    N --> O

    O --> P --> Q --> R

    R --> S --> T --> U --> V --> W

    W --> X --> Y

