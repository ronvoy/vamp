# OpenRouter - all LLM calls + transcription (single key)
OPENROUTER_API_KEY=

# Optional: override transcription model (default: google/gemini-2.5-flash)
# TRANSCRIBE_MODEL=google/gemini-2.5-flash

# Default agent for code gen: openai | anthropic
DEFAULT_AGENT=openai

# Port
PORT=5000

# Root URL prefix when deployed under a subpath (e.g. /vamp)
# Leave empty for root deployment
ROOT_URL=
